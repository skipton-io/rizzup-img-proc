{
  "name": "rizzup-img-proc",
  "version": "0.1.0",
  "private": true,
  "description": "Windows-hosted Netlify Blobs worker for the rizzup.co.uk image backend",
  "scripts": {
    "clean": "powershell -NoProfile -Command \"Remove-Item -Recurse -Force dist -ErrorAction SilentlyContinue\"",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/index.js",
    "test": "node --test dist/tests/**/*.test.js",
    "test:python": ".venv\\Scripts\\python.exe -m unittest discover -s tests_python -p \"test_*.py\""
  },
  "dependencies": {
    "@netlify/blobs": "^10.7.4"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18"
  }
}
