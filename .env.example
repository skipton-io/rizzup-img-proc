NETLIFY_SITE_ID=your-netlify-site-id
NETLIFY_ACCESS_TOKEN=your-netlify-personal-access-token

RIZZUP_QUEUE_STORE=rizzup-job-queue
RIZZUP_STATUS_STORE=rizzup-job-status
RIZZUP_RESULTS_STORE=rizzup-job-results
RIZZUP_LOCKS_STORE=rizzup-job-locks
RIZZUP_DEAD_LETTER_STORE=rizzup-job-dead-letter

RIZZUP_POLL_INTERVAL_MS=5000
RIZZUP_MAX_JOBS_PER_POLL=8
